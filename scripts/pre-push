#!/usr/bin/env bash
set -euo pipefail

TARGET="x86_64-pc-windows-msvc"

echo "Running pre-push checks (target: $TARGET)..."

echo "  fmt"
cargo fmt --all -- --check
cargo fmt --manifest-path bindings/node/Cargo.toml -- --check

echo "  clippy"
cargo clippy --workspace --all-targets --target "$TARGET" -- -D warnings

echo "  test (check)"
cargo check --workspace --all-targets --target "$TARGET"

echo "All checks passed."
